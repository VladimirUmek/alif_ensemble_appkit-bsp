    "version": "0.2.0",
    "configurations": [
        {
            "name": "M55_HP Core0 (launch - pyOCD)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "out/core0/Alif-AppKit-E7/Debug/core0.axf",
            "gdb": "arm-none-eabi-gdb",
            "preLaunchTask": "CMSIS Load",
            "initCommands": [
                "monitor reset halt",
                "tbreak main"
            ],
            "target": {
                "server": "pyocd",
                "serverParameters": [
                    "--probe", "cmsisdap:"
                ],
                "port": "3333"
            },
            "cmsis": {
                "cbuildRunFile": "Alif-AppKit-E7.cbuild-run.yml"
            }
        },
        {
            "name": "M55_HE Core1 (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "program": "out/core1/Alif-AppKit-E7/Debug/core1.axf",
            "gdb": "arm-none-eabi-gdb",
            "target": {
                "port": "3334"
            },
        },
