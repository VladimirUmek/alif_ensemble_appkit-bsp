        {
            "name": "M55_HP Core0 (launch - J-LINK)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "out/core0/Alif-AppKit-E7/Debug/core0.axf",
            "gdb": "arm-none-eabi-gdb",
            "initCommands": [
                "load out/core0/Alif-AppKit-E7/Debug/core0.hex",
                "set $control = 0",                // CONTROL regsiter
                "set $msp = __Vectors[0]",         // Main Stack Pointer (MSP)
                "set $pc  = __Vectors[1]",         // Program Counter (PC)
                "set *0xe000ed08 = __Vectors",     // SCB->VTOR
                "set *0xe000e010 = 0x00000000",    // SysTick=>CTRL = 0 (disable SysTick)
                "set *0xe000ed04 = 0x02000000",    // SCB->ICSR = SCB_ICSR_PENDSTCLR_Msk (clear SysTick pending exception)
                "tbreak main"
            ],
            "target": {
                "server": "JLinkGDBServer",
                "serverParameters": [
                    "-device", "AE722F80F55D5_HP",
                    // "-device", "${command:cmsis-csolution.getDeviceName}_${command:cmsis-csolution.getProcessorName}",
                    // "-JLinkDevicesXmlPath", ".alif/JLinkDevices.xml",
                    "-endian", "little",
                    "-if", "SWD",
                    "-speed", "auto",
                    "-noir",
                    "-vd",
                    "-nogui",
                    "-localhostonly"
                ],
                "port": "3333"
            }
        },
        {
            "name": "M55_HE Core1 (launch - J-LINK)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "out/core1/Alif-AppKit-E7/Debug/core1.axf",
            "gdb": "arm-none-eabi-gdb",
            "initCommands": [
                "load out/core1/Alif-AppKit-E7/Debug/core1.hex",
                "set $control = 0",                // CONTROL regsiter
                "set $msp = __Vectors[0]",         // Main Stack Pointer (MSP)
                "set $pc  = __Vectors[1]",         // Program Counter (PC)
                "set *0xe000ed08 = __Vectors",     // SCB->VTOR
                "set *0xe000e010 = 0x00000000",    // SysTick=>CTRL = 0 (disable SysTick)
                "set *0xe000ed04 = 0x02000000",    // SCB->ICSR = SCB_ICSR_PENDSTCLR_Msk (clear SysTick pending exception)
                "tbreak main"
            ],
            "target": {
                "server": "JLinkGDBServer",
                "serverParameters": [
                    "-device", "AE722F80F55D5_HE",
                    // "-device", "${command:cmsis-csolution.getDeviceName}_${command:cmsis-csolution.getProcessorName}",
                    // "-JLinkDevicesXmlPath", ".alif/JLinkDevices.xml",
                    "-endian", "little",
                    "-if", "SWD",
                    "-speed", "auto",
                    "-noir",
                    "-vd",
                    "-nogui",
                    "-localhostonly"
                ],
                "port": "3334"
            }
        },
    ]
}