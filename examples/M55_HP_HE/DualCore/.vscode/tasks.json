{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMSIS Erase",
            "type": "shell",
            "command": [
                "echo Connect > .cmd.jlink &&",
                "echo Erase >> .cmd.jlink &&",
                "echo Exit >> .cmd.jlink &&",
                "jlink -device AE722F80F55D5LS:M55_HP -if SWD -speed auto -commandfile .cmd.jlink"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load",
            "type": "shell",
            "command": [
                "echo Connect > .cmd.jlink &&",
                "echo LoadFile out/core0/Alif-AppKit-E7/Debug/core0.hex >> .cmd.jlink &&",
                "echo LoadFile out/core1/Alif-AppKit-E7/Debug/core1.hex >> .cmd.jlink &&",
                "echo Exit >> .cmd.jlink &&",
                "jlink -device AE722F80F55D5LS:M55_HP -if SWD -speed auto -commandfile .cmd.jlink"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Run",
            "type": "shell",
            "command": "JLinkGDBServerCL",
            "args": [
                "-device",
                "AE722F80F55D5LS:M55_HP",
                "-endian",
                "little",
                "-if",
                "SWD",
                "-speed",
                "auto",
                "-nohalt",
                "-noir",
                "-nogui",
                "-localhostonly",
                "-port",
                "3333"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load+Run",
            "type": "shell",
            "dependsOn": [
                "CMSIS Load",
                "CMSIS Run"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}